# Override the JSON data origin (default: production frostmaiden GitHub Pages site).
# For local development against a local Quartz dev server:
#   VITE_DATA_BASE_URL=http://localhost:8080/static/data
#   VITE_WIKI_BASE_URL=http://localhost:8080
VITE_DATA_BASE_URL=https://seyo.github.io/frostmaiden-campaign/static/data
VITE_WIKI_BASE_URL=https://seyo.github.io/frostmaiden-campaign

# Set to "0" to consume vellum-ds from its built dist/ instead of source.
# Defaults to "1" in dev mode (see vite.config.ts).
# VITE_USE_DS_SOURCE=1
